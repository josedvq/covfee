# Project folder containing app.py and development.env.
PROJECT_DIR=./samples/basic

# Public host used in generated dev URLs.
COVFEE_HOST=localhost
# Public port used in generated dev URLs.
COVFEE_PORT=5001

# Backend bind host.
COVFEE_BIND_HOST=0.0.0.0
# Backend bind port.
COVFEE_BIND_PORT=5001

# Webpack dev server host.
COVFEE_WEBPACK_DEVSERVER_HOST=localhost

# Enable admin auth in dev when true.
COVFEE_DEV_SAFE=false

# Redux store host exposed to the backend.
COVFEE_REDUX_STORE_HOST=127.0.0.1
# Redux store port.
COVFEE_REDUX_STORE_PORT=5555
# Restart the Redux store on file changes when true.
COVFEE_STORE_WATCH=true

# Standalone www server host.
COVFEE_WWW_SERVER_HOST=127.0.0.1
# Standalone www server port.
COVFEE_WWW_SERVER_PORT=8000
